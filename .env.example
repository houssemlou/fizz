# Server
ADDR=:8081
GIN_MODE=release
ENV=dev          # dev | prod — API key check is skipped in dev
API_KEY=change-me
METRICS_ADDR=:9091

# Database
DATABASE_URL=postgres://fizz:fizz@localhost:5433/fizz?sslmode=disable

# Kafka
KAFKA_BROKER=localhost:9094

# Logging — format: json (prod) | text (local dev)
#           level:  debug | info | warn | error
LOG_FORMAT=json
LOG_LEVEL=info
